# Backend environment variables for deployment
# Copy to .env for local development, or set in Railway dashboard for production

# Debug mode — defaults to false (production-safe). Set to true for local dev.
DEBUG=true

# Required: Anthropic API key (for AI-assisted generation)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Frontend URL for CORS (set to your Vercel deployment URL)
FRONTEND_URL=https://your-app.vercel.app

# Optional: Mapbox token (for geocoding features)
MAPBOX_TOKEN=pk.eyJ...

# Optional: Database URL override (default: SQLite in ./data/goldbeck.db)
# DATABASE_URL=sqlite+aiosqlite:///data/goldbeck.db

# Optional: Database directory (default: ./data/)
# DB_DIR=/data

# Set by Railway automatically:
# PORT=8000
